# Alibaba DashScope API (region-specific - must match DASHSCOPE_REGION)
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_REGION=singapore

# Alibaba Cloud OSS
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# Application Settings
MAX_FILE_SIZE_MB=500
MAX_AUDIO_DURATION_MINUTES=120
JOB_TTL_SECONDS=3600
TEMP_DIR=/tmp/meetingmind
TOKEN_PRICE_PER_1K=0.0002
POLL_INTERVAL_SECONDS=15

# Security & Rate Limits
MAX_SUMMARY_TOKENS=8000
RATE_LIMIT_UPLOADS_PER_MINUTE=10
RATE_LIMIT_SUMMARIES_PER_MINUTE=5
